# FIFA World Cup 2026 Tracker - Environment Variables Template

# =========================================================================
# SCORE SERVICE MODE (API Integration)
# =========================================================================
# Set to 'REAL' to enable live football API integrations.
# If left blank or set to 'SIMULATION', the website operates in 
# full local-simulation mode using localStorage databases (fully 
# editable in real-time via the Admin Backup Panel).
VITE_SCORE_MODE=SIMULATION

# =========================================================================
# EXTERNAL FOOTBALL API CREDENTIALS (IF VITE_SCORE_MODE=REAL)
# =========================================================================
# Mapped provider. Supported options: API-FOOTBALL | FOOTBALL-DATA
VITE_FOOTBALL_API_PROVIDER=API-FOOTBALL

# Your subscription API keys from the provider portal
VITE_FOOTBALL_API_KEY=your_api_key_here
